{
  "name": "deepm8-backend",
  "version": "1.0.0",
  "description": "DeepM8 Chess Training Backend - Stockfish + Multiplayer",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": ["chess", "stockfish", "multiplayer", "socket.io"],
  "author": "DeepM8",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.8.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "chess.js": "^1.0.0-beta.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/cors": "^2.8.17",
    "typescript": "^5.4.5",
    "tsx": "^4.7.2",
    "prettier": "^3.2.5",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
